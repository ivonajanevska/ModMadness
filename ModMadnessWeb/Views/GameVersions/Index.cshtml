@model IEnumerable<ModMadnessDomain.Domain.GameVersion>

@{
    ViewData["Title"] = "Index";
}
@if (ViewBag.SelectedGame != null)
{
    <div class="alert alert-dark shadow-sm d-flex justify-content-between align-items-center">
        <span>
            <i class="bi bi-controller text-info"></i>
            Showing items for: <strong>@ViewBag.SelectedGame</strong>
        </span>
        <a asp-action="Index" class="btn btn-sm btn-outline-light text-dark border">Show All</a>
    </div>
}
<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.VersionNumber)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Game)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.VersionNumber)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Game.Author)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
